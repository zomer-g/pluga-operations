rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helper functions =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function userId() {
      return request.auth.uid;
    }

    // Get the user's permission doc
    function getUserPerm() {
      return get(/databases/$(database)/documents/userPermissions/$(userId())).data;
    }

    // Check if user permission doc exists
    function hasUserPerm() {
      return exists(/databases/$(database)/documents/userPermissions/$(userId()));
    }

    // Get a permission group doc
    function getGroup(groupId) {
      return get(/databases/$(database)/documents/permissionGroups/$(groupId)).data;
    }

    // Check if user has a permission doc (bootstrap case: no doc = first user)
    function isVerifiedUser() {
      return isAuthenticated() && (hasUserPerm() || !exists(/databases/$(database)/documents/userPermissions/$(userId())));
    }

    // Check if a specific group grants at least 'view' for a route
    function groupHasView(groupId, route) {
      let group = getGroup(groupId);
      return group.pagePermissions[route] in ['view', 'edit', 'admin'];
    }

    // Check if a specific group grants at least 'edit' for a route
    function groupHasEdit(groupId, route) {
      let group = getGroup(groupId);
      return group.pagePermissions[route] in ['edit', 'admin'];
    }

    // Check if a specific group grants 'admin' for a route
    function groupHasAdmin(groupId, route) {
      let group = getGroup(groupId);
      return group.pagePermissions[route] == 'admin';
    }

    // Check read permission: user is authenticated + has permission doc
    // Firestore limits: can't iterate arrays, so we check up to 3 groups
    function canReadRoute(route) {
      return isAuthenticated() && (
        // Bootstrap: no permission doc yet (first user)
        !hasUserPerm() ||
        // Custom override
        (getUserPerm().keys().hasAll(['customPageOverrides']) &&
         getUserPerm().customPageOverrides[route] in ['view', 'edit', 'admin']) ||
        // Check first 3 group memberships
        (getUserPerm().groupIds.size() > 0 && groupHasView(getUserPerm().groupIds[0], route)) ||
        (getUserPerm().groupIds.size() > 1 && groupHasView(getUserPerm().groupIds[1], route)) ||
        (getUserPerm().groupIds.size() > 2 && groupHasView(getUserPerm().groupIds[2], route))
      );
    }

    // Check write permission: at least 'edit' on route
    function canWriteRoute(route) {
      return isAuthenticated() && (
        !hasUserPerm() ||
        (getUserPerm().keys().hasAll(['customPageOverrides']) &&
         getUserPerm().customPageOverrides[route] in ['edit', 'admin']) ||
        (getUserPerm().groupIds.size() > 0 && groupHasEdit(getUserPerm().groupIds[0], route)) ||
        (getUserPerm().groupIds.size() > 1 && groupHasEdit(getUserPerm().groupIds[1], route)) ||
        (getUserPerm().groupIds.size() > 2 && groupHasEdit(getUserPerm().groupIds[2], route))
      );
    }

    // Check admin permission on route
    function canAdminRoute(route) {
      return isAuthenticated() && (
        !hasUserPerm() ||
        (getUserPerm().keys().hasAll(['customPageOverrides']) &&
         getUserPerm().customPageOverrides[route] == 'admin') ||
        (getUserPerm().groupIds.size() > 0 && groupHasAdmin(getUserPerm().groupIds[0], route)) ||
        (getUserPerm().groupIds.size() > 1 && groupHasAdmin(getUserPerm().groupIds[1], route)) ||
        (getUserPerm().groupIds.size() > 2 && groupHasAdmin(getUserPerm().groupIds[2], route))
      );
    }

    // Simplified checks for collections that map to a specific page route
    function canRead() {
      return isAuthenticated();
    }

    function canWrite() {
      return isAuthenticated() && hasUserPerm();
    }

    // ===== Collection rules =====

    // Soldiers — mapped to /soldiers route
    match /soldiers/{soldierDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.id is string;
      allow update: if canWrite();
      allow delete: if canWrite();
    }

    // Status entries — part of soldier management
    match /statusEntries/{entryDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.soldierId is string
        && request.resource.data.status is string
        && request.resource.data.startDate is string;
      allow update, delete: if canWrite();
    }

    // Tanks
    match /tanks/{tankDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.designation is string
        && request.resource.data.type is string
        && request.resource.data.status is string;
      allow update, delete: if canWrite();
    }

    // Tank crew assignments
    match /tankCrewAssignments/{crewDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.tankId is string
        && request.resource.data.soldierId is string
        && request.resource.data.role is string;
      allow update, delete: if canWrite();
    }

    // Departments
    match /departments/{deptDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string;
      allow update, delete: if canWrite();
    }

    // Platoons
    match /platoons/{platoonDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string;
      allow update, delete: if canWrite();
    }

    // Squads
    match /squads/{squadDoc} {
      allow read: if canRead();
      allow write: if canWrite();
    }

    // Equipment types
    match /equipmentTypes/{typeDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string
        && request.resource.data.nameHe is string
        && request.resource.data.category is string;
      allow update, delete: if canWrite();
    }

    // Equipment assignments
    match /equipmentAssignments/{assignDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.soldierId is string
        && request.resource.data.equipmentTypeId is string
        && request.resource.data.signedOutDate is string;
      allow update, delete: if canWrite();
    }

    // Shampaf entries
    match /shampafEntries/{entryDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.soldierId is string
        && request.resource.data.startDateTime is string
        && request.resource.data.endDateTime is string;
      allow update, delete: if canWrite();
    }

    // Shampaf vacations
    match /shampafVacations/{vacDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.shampafEntryId is string
        && request.resource.data.soldierId is string
        && request.resource.data.startDateTime is string
        && request.resource.data.endDateTime is string;
      allow update, delete: if canWrite();
    }

    // Assignments
    match /assignments/{assignDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.soldierId is string
        && request.resource.data.type in ['tank_role', 'general_mission']
        && request.resource.data.startDateTime is string
        && request.resource.data.endDateTime is string;
      allow update, delete: if canWrite();
    }

    // Activations
    match /activations/{actDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string;
      allow update, delete: if canWrite();
    }

    // Routine departments
    match /routineDepartments/{deptDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string;
      allow update, delete: if canWrite();
    }

    // Routine vehicles
    match /routineVehicles/{vehicleDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.designation is string;
      allow update, delete: if canWrite();
    }

    // Routine templates
    match /routineTemplates/{templateDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string
        && request.resource.data.tankId is string;
      allow update, delete: if canWrite();
    }

    // Training content
    match /trainingContent/{contentDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.title is string
        && request.resource.data.contentType is string
        && request.resource.data.category is string;
      allow update, delete: if canWrite();
    }

    // Training tags
    match /trainingTags/{tagDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string;
      allow update, delete: if canWrite();
    }

    // Training categories
    match /trainingCategories/{catDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string;
      allow update, delete: if canWrite();
    }

    // Donations
    match /donations/{donDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.donorName is string
        && request.resource.data.type in ['monetary', 'equipment', 'supplies', 'other']
        && request.resource.data.description is string
        && request.resource.data.date is string;
      allow update, delete: if canWrite();
    }

    // User permissions — special rules
    match /userPermissions/{permUserId} {
      // Any authenticated user can read their own doc; users with perm can read others
      allow read: if isAuthenticated() && (permUserId == userId() || hasUserPerm());
      // User can create their own permission doc (bootstrap on first login)
      allow create: if isAuthenticated() && permUserId == userId()
        && request.resource.data.email is string
        && request.resource.data.displayName is string;
      // Users can update their own doc (migration) or admins can update any
      allow update: if isAuthenticated() && (permUserId == userId() || canWrite());
      allow delete: if canWrite();
    }

    // Permission groups — readable by authenticated users, writable by users with perm
    match /permissionGroups/{groupDoc} {
      allow read: if canRead();
      allow create: if canWrite()
        && request.resource.data.name is string;
      allow update, delete: if canWrite();
    }

    // Changelog entries for routine
    match /routineChangelog/{logDoc} {
      allow read: if canRead();
      allow create: if canWrite();
      allow update, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
